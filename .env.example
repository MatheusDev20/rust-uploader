AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name_here


# Postgres superuser — only used during container init, never by the app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_root_password_here
POSTGRES_DB=minitube

# App database user — created by db/init.sh with least-privilege access
DB_USER=minitube_user
DB_PASSWORD=your_app_db_password_here
DATABASE_URL=postgresql://minitube_user:your_app_db_password_here@localhost:5432/minitube